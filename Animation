<style>
  #automation-story {
    display: flex;
    justify-content: space-between;
    align-items: center;
    background: #0f172a;
    padding: 2rem;
    border-radius: 12px;
    font-family: system-ui, -apple-system, sans-serif;
    color: white;
    overflow: hidden;
    position: relative;
    height: 350px;
  }

  .zone {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    position: relative;
    height: 100%;
  }

  .zone-title {
    position: absolute;
    top: 0;
    font-size: 0.875rem;
    text-transform: uppercase;
    letter-spacing: 1px;
    color: #94a3b8;
  }

  /* Chaos Zone */
  #chaos-zone .packet {
    width: 20px;
    height: 20px;
    background: #ef4444;
    position: absolute;
    border-radius: 4px;
    transition: all 1s ease-in-out;
  }

  /* Nodes */
  .node-path {
    display: flex;
    align-items: center;
    gap: 1rem;
    z-index: 10;
  }

  .node {
    background: #1e293b;
    border: 2px solid #3b82f6;
    padding: 1rem;
    border-radius: 8px;
    font-size: 0.875rem;
    font-weight: 600;
    text-align: center;
    box-shadow: 0 4px 6px -1px rgb(0 0 0 / 0.1);
  }

  .arrow {
    color: #3b82f6;
    font-weight: bold;
  }

  /* Clean Zone */
  #clean-zone {
    display: flex;
    flex-direction: column;
    gap: 8px;
    justify-content: center;
  }

  .clean-record {
    width: 120px;
    height: 12px;
    background: #10b981;
    border-radius: 4px;
    opacity: 0;
    transform: translateX(-20px);
    transition: all 0.5s ease-out;
  }

  /* Controls */
  .controls {
    position: absolute;
    bottom: 1rem;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    gap: 1rem;
  }

  button {
    background: #3b82f6;
    color: white;
    border: none;
    padding: 0.5rem 1rem;
    border-radius: 6px;
    cursor: pointer;
    font-weight: bold;
  }

  button:hover {
    background: #2563eb;
  }

  #btn-reset {
    background: #475569;
  }
  
  #btn-reset:hover {
    background: #334155;
  }
</style>

<div id="automation-story">
  <!-- Left: Chaos -->
  <div class="zone" id="chaos-zone">
    <div class="zone-title">Raw Inputs</div>
    <!-- Packets generated by JS -->
  </div>

  <!-- Center: Nodes -->
  <div class="zone" style="flex: 2;">
    <div class="zone-title">Intelligent Workflow</div>
    <div class="node-path">
      <div class="node" id="node-1">Webhook Input</div>
      <div class="arrow">&rarr;</div>
      <div class="node" id="node-2">Workflow Optimized</div>
      <div class="arrow">&rarr;</div>
      <div class="node" id="node-3">CRM Record</div>
    </div>
  </div>

  <!-- Right: Clean -->
  <div class="zone" id="clean-zone">
    <div class="zone-title">Sleek Dashboard</div>
    <!-- Clean records generated by JS -->
  </div>

  <div class="controls">
    <button id="btn-run">Run Process</button>
    <button id="btn-reset">Reset</button>
  </div>
</div>

<script>
  const chaosZone = document.getElementById('chaos-zone');
  const cleanZone = document.getElementById('clean-zone');
  const runBtn = document.getElementById('btn-run');
  const resetBtn = document.getElementById('btn-reset');
  let packets = [];
  let records = [];

  function init() {
    chaosZone.innerHTML = '<div class="zone-title">Raw Inputs</div>';
    cleanZone.innerHTML = '<div class="zone-title">Sleek Dashboard</div>';
    packets = [];
    records = [];

    // Create messy inputs
    for (let i = 0; i < 5; i++) {
      const packet = document.createElement('div');
      packet.className = 'packet';
      packet.style.top = `${Math.random() * 60 + 20}%`;
      packet.style.left = `${Math.random() * 60 + 20}%`;
      packet.style.transform = `rotate(${Math.random() * 360}deg)`;
      chaosZone.appendChild(packet);
      packets.push(packet);

      // Create clean targets
      const record = document.createElement('div');
      record.className = 'clean-record';
      cleanZone.appendChild(record);
      records.push(record);
    }
  }

  runBtn.addEventListener('click', () => {
    runBtn.disabled = true;
    const node1 = document.getElementById('node-1').getBoundingClientRect();
    const container = document.getElementById('automation-story').getBoundingClientRect();

    packets.forEach((packet, index) => {
      setTimeout(() => {
        // Move to first node
        packet.style.top = `${node1.top - container.top + 15}px`;
        packet.style.left = `${node1.left - container.left + 30}px`;
        packet.style.transform = 'rotate(0deg)';
        packet.style.background = '#3b82f6'; // Turn blue

        // Fade out packet and fade in clean record
        setTimeout(() => {
          packet.style.opacity = '0';
          records[index].style.opacity = '1';
          records[index].style.transform = 'translateX(0)';
        }, 1000);
      }, index * 400); // Stagger the animation
    });
  });

  resetBtn.addEventListener('click', () => {
    runBtn.disabled = false;
    init();
  });

  // Initialize on load
  init();
</script>
